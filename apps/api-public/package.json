{
	"name": "@repo/api-public",
	"version": "1.0.50",
	"module": "src/index.js",
	"scripts": {
		"dev": "bun run --watch src/index.ts",
		"build": "bun build src/index.ts --target bun --outdir ./dist",
		"check-types": "tsc --noEmit",
		"start": "NODE_ENV=production bun dist/index.js",
		"test": "bun test",
		"benchmark": "BENCHMARK_DURATION=60s BENCHMARK_CONNECTIONS=300 bun ./benchmark.ts"
	},
	"dependencies": {
		"@elysiajs/cors": "^1.4.1",
		"@elysiajs/openapi": "^1.4.14",
		"@elysiajs/server-timing": "^1.4.0",
		"@sentry/bun": "^10.44.0",
		"drizzle-orm": "^0.45.1",
		"drizzle-zod": "^0.8.3",
		"elysia": "latest",
		"ioredis": "^5.10.0",
		"pg": "^8.20.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@repo/typescript-config": "workspace:*",
		"@types/bun": "^1.3.10",
		"@types/pg": "^8.18.0",
		"drizzle-kit": "^0.31.10"
	}
}
